{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.4.0/schema.json",
  "name": "barchart01",
  "position": {
    "x": 100,
    "y": 100,
    "z": 0,
    "height": 400,
    "width": 600
  },
  "visual": {
    "visualType": "barChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Player by GW"
                    }
                  },
                  "Property": "round"
                }
              },
              "queryRef": "Player by GW.round",
              "nativeQueryRef": "round",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Player by GW"
                    }
                  },
                  "Property": "Pts by GW"
                }
              },
              "queryRef": "Player by GW.Pts by GW"
            }
          ]
        }
      }
    },
    "objects": {
      "categoryAxis": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ],
      "valueAxis": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    }
  }
}